# ── Required Settings ──────────────────────────────────────────────────────────

# OpenRouter API key (required for AI image analysis in Stage 3)
# Get yours at: https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# Access key for dashboard login (required)
ACCESS_KEY=your-access-key-here

# Flask session secret (required - use a random string)
SESSION_SECRET=your-random-secret-here

# Admin reset password (optional but recommended)
ADMIN_RESET_PASSWORD=your-admin-password-here

# ── Optional Settings ──────────────────────────────────────────────────────────

# Data directory (default: /data in Docker, ./data locally)
# DATA_DIR=/data

# Server port (default: 8080)
# PORT=8080

# ── AI Model Configuration (Stage 3) ──────────────────────────────────────────

# VLM model for visual analysis (default: rekaai/reka-edge)
# VLM_MODEL=rekaai/reka-edge

# LLM model for schema normalization (default: bytedance-seed/seed-1.6-flash)
# LLM_MODEL=bytedance-seed/seed-1.6-flash

# Max retries for VLM/LLM calls (default: 3)
# VLM_MAX_RETRIES=3

# Batch size for processing (default: 5)
# VLM_BATCH_SIZE=5

# Skip VLM and use metadata-only mode (default: false)
# Set to "true" if you don't have an OpenRouter key
# VLM_USE_FALLBACK=false